# ─────────────────────────────────────────────────────────────────────────────
# Clerk — https://dashboard.clerk.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────

# Public key shown in your app (safe to expose)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_

# Secret key — never expose client-side
CLERK_SECRET_KEY=sk_test_

# JWT template issuer URL — Clerk Dashboard → JWT Templates → Convex preset → Issuer field
# IMPORTANT: This value differs between Development and Production Clerk environments.
# Create the JWT template in each environment and use the matching issuer URL.
# Dev example:  https://alert-shrew-70.clerk.accounts.dev
# Prod example: https://clerk.yourdomain.com
CLERK_JWT_ISSUER_DOMAIN=

# Clerk routing (these values are fixed — don't change unless you move the pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard


# ─────────────────────────────────────────────────────────────────────────────
# Convex — output from `npx convex dev`
# ─────────────────────────────────────────────────────────────────────────────

# Your Convex deployment URL (shown after `npx convex dev` initialises)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Deploy key — Convex Dashboard → Settings → Deploy Key
# Used in API routes (webhook, portal) to call Convex server-side
CONVEX_DEPLOY_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Stripe — https://dashboard.stripe.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────

# Secret key — server-side only, never expose client-side
STRIPE_SECRET_KEY=sk_test_

# Publishable key — safe to expose in the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook signing secret
# Dev: `stripe listen --print-secret` (or shown when you run `stripe listen`)
# Prod: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_

# Price IDs — Stripe Dashboard → Products → your product → price ID (starts with price_)
STRIPE_PRO_MONTHLY_PRICE_ID=price_
STRIPE_PRO_YEARLY_PRICE_ID=price_
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_
STRIPE_BUSINESS_YEARLY_PRICE_ID=price_


# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare R2 (optional — remove app/api/assets/route.ts if not using)
# ─────────────────────────────────────────────────────────────────────────────

# Cloudflare account ID — Cloudflare Dashboard → right sidebar
R2_ACCOUNT_ID=

# R2 API token credentials — Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Your R2 bucket name
R2_BUCKET_NAME=


# ─────────────────────────────────────────────────────────────────────────────
# Image-search providers (all optional — missing keys mean that provider is
# skipped at runtime; Wikimedia is always enabled and needs no key)
# ─────────────────────────────────────────────────────────────────────────────

# Pixabay — https://pixabay.com/api/docs/ (free tier: 5,000 req/hour)
PIXABAY_API_KEY=

# Unsplash — https://unsplash.com/developers (free demo tier: 50 req/hour)
UNSPLASH_ACCESS_KEY=

# Pexels — https://www.pexels.com/api/ (free tier: 200 req/hour, 20k/month)
PEXELS_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Deepgram — voice search fallback (non-Chrome browsers)
# https://console.deepgram.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────

# Master API key — server-only. The /api/speech/token route uses it to mint
# short-lived (30s) access tokens for the browser; the master key never reaches
# the client. The key needs scope to grant tokens (Member/Owner key).
# Absent = the Deepgram fallback is disabled; Chrome's Web Speech API still works.
DEEPGRAM_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────

# Your production URL — used in sitemap.ts and OG meta tags
# Dev: http://localhost:3000
# Prod: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────────────────────
# Product analytics (PostHog) — optional
# ─────────────────────────────────────────────────────────────────────────────

# Project token from PostHog dashboard → Project Settings → "Project token & ID".
# Starts with `phc_...`. Public by design — safe to expose to the client.
# Absent = no-op: track() calls are skipped, no events sent.
NEXT_PUBLIC_POSTHOG_KEY=phc_

# PostHog ingestion endpoint. NOT the dashboard URL — note the `.i.` subdomain.
# US Cloud: https://us.i.posthog.com   (dashboard lives at https://us.posthog.com)
# EU Cloud: https://eu.i.posthog.com   (dashboard lives at https://eu.posthog.com)
# The SDK's `init({ api_host: ... })` call shown in the PostHog onboarding
# install snippet is the canonical source for the right value.
# (EU vs US dashboards are completely separate; revisit if enterprise / NHS /
# school-district customers ever require strict UK/EU data residency.)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

